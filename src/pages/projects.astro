---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Projects"
  description="Mechanical engineering projects by Jacky Huynh."
>
  <section class="hero">
    <p class="eyebrow">Projects</p>

    <h1>Engineering Projects</h1>

    <p class="intro">
      A selection of engineering projects focused on design, simulation,
      prototyping, and problem-solving.
    </p>
  </section>

  <section class="project-grid">
    <a class="project-card" href="/projects/propeller-optimization">
      <div class="project-image"></div>

      <div class="project-content">
        <h2>Autonomous Boat Propeller Optimization</h2>

        <p>
          Designed, simulated, and tested propeller geometries to improve
          performance for an autonomous boat platform.
        </p>

        <span>CAD • Simulation • Testing</span>
      </div>
    </a>

    <a class="project-card" href="/projects/lidar-casing">
      <div class="project-image"></div>

      <div class="project-content">
        <h2>Water-Resistant LiDAR Camera Casing</h2>

        <p>
          Designed and fabricated a protective enclosure for a LiDAR camera
          system used in outdoor environments.
        </p>

        <span>Design • Prototyping • Manufacturing</span>
      </div>
    </a>

    <a class="project-card" href="/projects/senior-design">
      <div class="project-image"></div>

      <div class="project-content">
        <h2>Senior Design Project</h2>

        <p>
          Led a multidisciplinary team through the design, planning, and
          execution of a capstone engineering project.
        </p>

        <span>Leadership • Project Management</span>
      </div>
    </a>
  </section>
</MainLayout>

<style>
  .hero {
    max-width: 48rem;
    margin-bottom: 4rem;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .intro {
    max-width: 42rem;
    font-size: 1.125rem;
  }

  .project-grid {
    display: grid;
    gap: 2rem;
  }

  .project-card {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 2rem;

    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;

    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .project-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.06);
  }

  .project-image {
    background: var(--border);
    min-height: 220px;
  }

  .project-content {
    padding: 2rem;
  }

  .project-content span {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
  }

  @media (max-width: 900px) {
    .project-card {
      grid-template-columns: 1fr;
    }

    .project-image {
      min-height: 180px;
    }
  }
</style>
---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />

    <main>
      <h1>Jacky Huynh</h1>

      <p>
        Mechanical Engineer | Operations Leader | Problem Solver
      </p>

      <p>
        I'm a Mechanical Engineering graduate from Temple University with
        experience leading business operations, managing projects, and building
        practical solutions.
      </p>

      <p>
        I'm currently pursuing opportunities in mechanical engineering while
        showcasing my technical projects, leadership experience, and continuous
        learning.
      </p>

      <h2>Featured Projects</h2>

      <ul>
        <li>Autonomous Boat Propeller Optimization</li>
        <li>Water-Resistant LiDAR Camera Casing</li>
        <li>Senior Design Project Leadership</li>
      </ul>

      <p>
        <a href="/about">About Me</a> |
        <a href="/blog">Projects & Blog</a>
      </p>
    </main>

    <Footer />
  </body>
</html>
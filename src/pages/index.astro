---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Jacky Huynh"
  description="Mechanical Engineer with a Background in Business Operations"
>

  <section class="hero">
    <div class="hero-content">

      <p class="eyebrow">
      JACKY HUYNH • MECHANICAL ENGINEER
      </p>

      <h2>
        Mechanical Engineer with a Background in Business Operations
      </h2>

      <p>
        Mechanical Engineering graduate from Temple University with experience
        leading business operations, managing projects, and building practical
        solutions.
      </p>

      <div class="hero-buttons">
        <a class="primary" href="/projects">View Projects</a>
        <a class="secondary" href="/resume">Download Resume</a>
      </div>
    </div>

    <div class="hero-image">
      <img src="/images/headshot.jpg" alt="Jacky Huynh" />
    </div>
  </section>

  <section>
    <h2>Featured Projects</h2>

    <div class="cards">
      <div class="card">
        <h3>Autonomous Boat Propeller Optimization</h3>
        <p>CAD design, simulation, testing, and iteration.</p>
      </div>

      <div class="card">
        <h3>Water-Resistant LiDAR Camera Casing</h3>
        <p>Mechanical design and prototyping.</p>
      </div>

      <div class="card">
        <h3>Senior Design Project</h3>
        <p>Cross-functional collaboration and leadership.</p>
      </div>
    </div>
  </section>

  <section>
    <h2>Quick Highlights</h2>

    <div class="cards">
      <div class="card">
        <h3>B.S. Mechanical Engineering</h3>
        <p>Temple University</p>
      </div>

      <div class="card">
        <h3>5+ Years</h3>
        <p>Operations Leadership</p>
      </div>

      <div class="card">
        <h3>CAD • Simulation</h3>
        <p>Project Management</p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 4rem;
    align-items: center;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .primary,
  .secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    min-width: 160px;
    min-height: 48px;

    padding: 0.5rem 1.5rem;

    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    text-align: center;

    box-sizing: border-box;
  }

  .primary {
    background: var(--accent);
    color: white;
  }

  .secondary {
    border: 1px solid var(--border);
    border-color: var(--accent);
    color: var(--accent);
  }

  .secondary {
  transition:
    background-color 0.2s ease,
    color 0.2s ease,
    border-color 0.2s ease;
  }

  .secondary:hover {
    background: var(--accent);
    color: var(--background);
    border-color: var(--accent);
  }

  .hero-image img {
    width: 100%;
    aspect-ratio: 1 / 1;

    border-radius: 15%;
    object-fit: cover;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  section + section {
    margin-top: 6rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .card {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);

    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 20px;

    padding: 2rem;

    box-shadow:
      0 8px 24px rgba(15, 23, 42, 0.04),
      0 1px 2px rgba(15, 23, 42, 0.04);

    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow:
      0 16px 32px rgba(15, 23, 42, 0.06),
      0 2px 8px rgba(15, 23, 42, 0.04);
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 3rem;
      min-height: auto;
    }

    .cards {
      grid-template-columns: 1fr;
    }

    .hero-image {
      max-width: 320px;
      width: 100%;
      margin: 0 auto;
    }

    .hero-image img {
      width: 100%;
      max-height: 400px;
      object-fit: cover;
    }
    
    .hero-buttons {
      flex-direction: column;
      align-items: flex-start;
      gap:.75rem;
    }

    .primary,
    .secondary {
      width: auto;
      min-width: 180px;
    }

  }

</style>
---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Jacky Huynh"
  description="Mechanical Engineering graduate with experience in engineering, operations, and leadership."
>
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">
        JACKY HUYNH • MECHANICAL ENGINEER
      </p>

      <h1>
        Engineering Graduate with Real-World Leadership Experience
      </h1>

      <p>
        Mechanical Engineering graduate from Temple University with experience
        leading business operations, managing projects, and developing
        practical solutions. I combine technical problem-solving with
        real-world leadership and operational experience.
      </p>

      <div class="hero-buttons">
        <a class="primary" href="/projects">View Projects</a>
        <a class="secondary" href="/experience">View Experience</a>
      </div>
    </div>

    <div class="hero-image">
      <img src="/images/headshot.jpg" alt="Jacky Huynh" />
    </div>
  </section>

  <section>
    <h2>My Journey</h2>

    <div class="cards">
      <a class="card" href="/experience/temple-university">
        <h3>Engineering Foundation</h3>

        <p class="card-subtitle">
          Temple University
        </p>

        <p>
          Developed a foundation in mechanical engineering through design,
          analysis, manufacturing, simulation, and multidisciplinary
          engineering projects.
        </p>
      </a>

      <a class="card" href="/experience/mcmaster-carr">
        <h3>Operational Discipline</h3>

        <p class="card-subtitle">
          McMaster-Carr
        </p>

        <p>
          Learned the value of process improvement, workplace safety,
          consistency, and continuous improvement within a highly structured
          operational environment.
        </p>
      </a>

      <a class="card" href="/experience/my-beloved-lash">
        <h3>Leadership Experience</h3>

        <p class="card-subtitle">
          My Beloved Lash
        </p>

        <p>
          Built and operated a business while managing projects, employees,
          systems, customers, and long-term organizational growth.
        </p>
      </a>
    </div>
  </section>

  <section class="current-focus">
    <h2>Current Focus</h2>

    <p>
      I'm currently seeking opportunities in mechanical engineering where I
      can contribute technical knowledge, operational experience, and a
      strong problem-solving mindset while continuing to grow as an engineer.
    </p>

    <div class="hero-buttons">
      <a class="primary" href="/contact">Contact Me</a>
      <a class="secondary" href="/resume">View Resume</a>
    </div>
  </section>
</MainLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 400px;
    gap: 4rem;
    align-items: center;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
  }

  .primary,
  .secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;

    min-width: 160px;
    min-height: 48px;

    padding: 0.5rem 1.5rem;

    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    text-align: center;

    box-sizing: border-box;
  }

  .primary {
    background: var(--accent);
    color: white;
  }

  .secondary {
    border: 1px solid var(--accent);
    color: var(--accent);

    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .secondary:hover {
    background: var(--accent);
    color: var(--background);
    border-color: var(--accent);
  }

  .hero-image img {
    width: 100%;
    aspect-ratio: 1 / 1;

    border-radius: 15%;
    object-fit: cover;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }

  section + section {
    margin-top: 6rem;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .card {
    background: rgba(255, 255, 255, 0.65);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);

    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 20px;

    padding: 2rem;

    box-shadow:
      0 8px 24px rgba(15, 23, 42, 0.04),
      0 1px 2px rgba(15, 23, 42, 0.04);

    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }

  a.card {
    color: inherit;
    text-decoration: none;
  }

  .card:hover {
    transform: translateY(-2px);

    box-shadow:
      0 16px 32px rgba(15, 23, 42, 0.06),
      0 2px 8px rgba(15, 23, 42, 0.04);
  }

  .card-subtitle {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-top: -0.5rem;
    margin-bottom: 1rem;
  }

  .current-focus {
    max-width: 48rem;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 3rem;
      min-height: auto;
    }

    .cards {
      grid-template-columns: 1fr;
    }

    .hero-image {
      max-width: 320px;
      width: 100%;
      margin: 0 auto;
    }

    .hero-image img {
      width: 100%;
      max-height: 400px;
      object-fit: cover;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .primary,
    .secondary {
      width: 240px;
      min-width: 0;
    }
  }
</style>
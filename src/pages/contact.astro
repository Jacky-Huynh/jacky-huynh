---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout
  title="Contact"
  description="Get in touch with Jacky Huynh."
>
  <section class="hero">
    <p class="eyebrow">Contact</p>

    <h1>Let's Connect</h1>

    <p class="intro">
      I'm currently seeking opportunities in mechanical engineering and am
      always open to discussing engineering, project management, operations,
      or potential career opportunities. Feel free to reach out.
    </p>

    <div class="contact-grid">
      <a
        class="contact-card"
        href="mailto:jthuynh06@gmail.com"
      >
        <h2>Email</h2>

        <p class="contact-info">
          jthuynh06@gmail.com
        </p>

        <p class="contact-subtitle">
          Send me a message
        </p>
      </a>

      <a
        class="contact-card"
        href="https://linkedin.com/in/jackyhuynh-me"
        target="_blank"
        rel="noopener noreferrer"
      >
        <h2>LinkedIn</h2>

        <p class="contact-info">
          linkedin.com/in/jackyhuynh-me
        </p>

        <p class="contact-subtitle">
          Connect professionally
        </p>
      </a>

    </div>

    <p class="closing">
      Whether you're looking to discuss an engineering opportunity,
      collaborate on a project, or simply connect, I'd be happy to hear
      from you.
    </p>
  </section>
</MainLayout>

<style>
  .hero {
    max-width: 64rem;
  }

  .eyebrow {
    color: var(--accent);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .intro {
    max-width: 42rem;
    font-size: 1.125rem;
    margin-bottom: 3rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .contact-card {
    display: block;

    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;

    padding: 2rem;

    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .contact-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.06);
  }

  .contact-card h2 {
    margin-top: 0;
    margin-bottom: 0.75rem;
  }

  .contact-info {
    margin-bottom: 0.5rem;
    font-weight: 500;
    word-break: break-word;
  }

  .contact-subtitle {
    margin-bottom: 0;
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .closing {
    max-width: 42rem;
    color: var(--text-secondary);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>  
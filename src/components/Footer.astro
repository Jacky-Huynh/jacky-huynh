---
const today = new Date();
---

<footer>
  <div class="footer-content">
    <div class="footer-top">
      <p>
        Building practical solutions through engineering and leadership.
      </p>
    </div>

    <div class="footer-bottom">
      <p>
	  © {today.getFullYear()} Jacky Huynh. All rights reserved.
	  </p>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 6rem;
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .footer-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .footer-top {
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .footer-top p,
  .footer-bottom p {
    margin: 0;
  }

  .footer-bottom {
    padding-top: 0.75rem;
  }

  @media (max-width: 768px) {
    .footer-content {
      padding: 1.25rem 1.5rem;
    }
  }
</style>
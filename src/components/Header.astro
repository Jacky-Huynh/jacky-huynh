---
import HeaderLink from './HeaderLink.astro';
import { SITE_LOGO } from '../consts';

const isHome = Astro.url.pathname === '/';
---

<header>
	<nav>
		<h2>
			<a href="/" class={isHome ? 'active-logo' : ''}>
			{SITE_LOGO}
			</a>
		</h2>

		<div class="internal-links desktop-nav">
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/experience">Experience</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/resume">Resume</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>

		<details class="mobile-nav">
			<summary aria-label="Open navigation menu">
			☰
			</summary>

			<div class="mobile-menu">
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/experience">Experience</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/resume">Resume</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
			</div>
		</details>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 1000;

		background: rgba(255, 255, 255, 0.72);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
	}

	nav {
		position: relative;

		max-width: 1200px;
		height: 48px;
		margin: 0 auto;
		padding: 0 1.5rem;

		display: flex;
		align-items: center;
		justify-content: center;
	}

	nav a {
		color: var(--text-secondary);
		font-size: 0.8rem;
		font-weight: 400;
		transition: color 0.2s ease;
	}

	nav a:hover {
		color: var(--text);
	}

	nav a.active {
		color: var(--text);
		font-weight: 600;
	}

	h2 {
		position: absolute;
		left: 1.5rem;

		margin: 0;
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	h2 a {
		color: var(--text-secondary);
		font-weight: 500;
		transition: color 0.2s ease, font-weight 0.2s ease;
	}

	h2 a:hover {
		color: var(--text);
	}

	h2 a.active-logo {
		color: var(--text);
		font-weight: 600;
	}

	.internal-links {
		display: flex;
		gap: 1.5rem;
	}

	.desktop-nav {
		display: flex;
		gap: 1.5rem;
	}

	.mobile-nav {
		display: none;
	}

	@media (max-width: 768px) {
		nav {
			justify-content: space-between;
		}

		h2 {
			position: static;
		}

		.desktop-nav {
			display: none;
		}

		.mobile-nav {
			display: block;
		}

		.mobile-nav summary {
			list-style: none;
			cursor: pointer;
			font-size: 1.25rem;
			color: var(--text);
		}

		.mobile-nav summary::-webkit-details-marker {
			display: none;
		}

		.mobile-menu {
			position: absolute;
			top: 48px;
			right: 1rem;

			display: flex;
			flex-direction: column;
			gap: 1rem;

			min-width: 180px;
			padding: 1rem;

			background: rgba(255, 255, 255, 0.95);
			backdrop-filter: blur(20px);
			-webkit-backdrop-filter: blur(20px);

			border: 1px solid var(--border);
			border-radius: 16px;

			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
		}
	}
</style>
